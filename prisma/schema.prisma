generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ===================== Core SaaS Models =====================

model User {
  id                String   @id @default(cuid())
  email             String   @unique
  passwordHash      String   @map("password_hash")
  name              String?
  phone             String?
  status            String   @default("pending_verification")
  emailVerifiedAt   DateTime? @map("email_verified_at")
  kycStatus         String?   @default("not_started") @map("kyc_status")
  twoFactorSecret   String?   @map("two_factor_secret")
  twoFactorEnabled  Boolean   @default(false) @map("two_factor_enabled")
  lastLoginAt       DateTime? @map("last_login_at")

  // === Onboarding Tracking ===
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")
  onboardingLocked      Boolean   @default(false) @map("onboarding_locked")

  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  ownedTenants      Tenant[]       @relation("TenantOwner")
  memberships       TenantMember[]
  paymentMethods    PaymentMethod[]
  auditLogs         AuditLog[]
  kycRecord         KYCRecord?
  mtAccounts        MTAccount[]
  wallets           Wallet[]
  transactions      Transaction[]
  ibPartner         IBPartner?

  @@map("users")
}

model Tenant {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  logoUrl         String?  @map("logo_url")
  status          String   @default("trial")
  region          String   @default("ap-southeast-1")
  timezone        String   @default("UTC")
  locale          String   @default("zh-CN")
  domainWhitelist String?  @map("domain_whitelist")
  trialEndsAt     DateTime? @map("trial_ends_at")
  ownerId         String   @map("owner_id")

  // === Branding & Whitelabel ===
  brandName       String?  @map("brand_name")
  slogan          String?
  faviconUrl      String?  @map("favicon_url")
  primaryColor    String?  @map("primary_color") @default("#1a73e8")
  subdomain       String?  @unique
  customDomain    String?  @unique @map("custom_domain")
  customDomainVerified Boolean @default(false) @map("custom_domain_verified")

  // === Plan & Limits ===
  plan            String   @default("mvp") // free, starter, professional, enterprise, ultimate
  maxUsers        Int      @default(10) @map("max_users")
  maxAccounts     Int      @default(5) @map("max_accounts")

  // === Trial & Lifecycle ===
  gracePeriodEndsAt DateTime? @map("grace_period_ends_at")
  retentionExpiresAt DateTime? @map("retention_expires_at")
  downgradeReason   String?   @map("downgrade_reason") // trial_expired, manual, admin

  // === Onboarding Control ===
  onboardingLocked Boolean @default(false) @map("onboarding_locked")
  onboardingCompletedAt DateTime? @map("onboarding_completed_at")

  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  owner       User           @relation("TenantOwner", fields: [ownerId], references: [id])
  members     TenantMember[]
  subscriptions Subscription[]
  licenses    License[]
  invoices    Invoice[]
  auditLogs   AuditLog[]
  onboarding  TenantOnboarding?
  apps        TenantApp[]
  config      TenantConfig?
  features    TenantFeature[]
  domains     TenantDomain[]
  notifications TenantNotification[]
  dataRetention TenantDataRetention?
  stripeCustomer StripeCustomer?

  @@map("tenants")
}

model TenantMember {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  userId    String   @map("user_id")
  role      String   @default("viewer")
  invitedAt DateTime @default(now()) @map("invited_at")
  joinedAt  DateTime? @map("joined_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([tenantId, userId])
  @@map("tenant_members")
}

model Product {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  description String?
  basePrice   Float    @map("base_price")
  seatPrice   Float?   @map("seat_price")
  currency    String   @default("USD")
  isActive    Boolean  @default(true) @map("is_active")
  features    String?  // JSON string
  createdAt   DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]

  @@map("products")
}

model Subscription {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  productId       String   @map("product_id")
  status          String   @default("active")
  planName        String   @map("plan_name")
  seatLimit       Int      @default(5) @map("seat_limit")
  currentSeats    Int      @default(1) @map("current_seats")
  startsAt        DateTime @default(now()) @map("starts_at")
  endsAt          DateTime? @map("ends_at")
  trialEndsAt     DateTime? @map("trial_ends_at")
  gracePeriodEndsAt DateTime? @map("grace_period_ends_at")
  autoRenew       Boolean  @default(true) @map("auto_renew")
  features        String?  @map("features")
  metadata        String?  @map("metadata")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant  Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])
  licenses License[]

  @@map("subscriptions")
}

model License {
  id              String   @id @default(cuid())
  key             String   @unique
  tenantId        String   @map("tenant_id")
  subscriptionId  String   @map("subscription_id")
  productCode     String   @map("product_code")
  status          String   @default("active")
  features        String?  @map("features")
  issuedAt        DateTime @default(now()) @map("issued_at")
  expiresAt       DateTime? @map("expires_at")
  revokedAt       DateTime? @map("revoked_at")
  lastValidatedAt DateTime? @map("last_validated_at")

  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  subscription Subscription @relation(fields: [subscriptionId], references: [id])

  @@map("licenses")
}

model Invoice {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  invoiceNumber String   @unique @map("invoice_number")
  periodStart   DateTime @map("period_start")
  periodEnd     DateTime @map("period_end")
  amount        Float
  currency      String   @default("USD")
  status        String   @default("pending")
  paidAt        DateTime? @map("paid_at")
  dueDate       DateTime @map("due_date")
  pdfUrl        String?  @map("pdf_url")
  metadata      String?  @map("metadata")

  // === Stripe Integration ===
  stripeCustomerId       String? @map("stripe_customer_id")
  stripeCheckoutSessionId String? @map("stripe_checkout_session_id")
  stripePaymentIntentId   String? @map("stripe_payment_intent_id")
  stripeSubscriptionId    String? @map("stripe_subscription_id")
  paymentMethod          String? @map("payment_method") // card, usdt, bank_transfer

  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("invoices")
}

model StripeCustomer {
  id              String   @id @default(cuid())
  tenantId        String   @unique @map("tenant_id")
  stripeCustomerId String  @unique @map("stripe_customer_id")
  email           String
  name            String?
  defaultCurrency String   @default("USD") @map("default_currency")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("stripe_customers")
}

model PaymentMethod {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String
  provider    String
  last4       String?
  brand       String?
  expiryMonth Int?     @map("expiry_month")
  expiryYear  Int?     @map("expiry_year")
  isDefault   Boolean  @default(false) @map("is_default")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payment_methods")
}

model AuditLog {
  id         String   @id @default(cuid())
  tenantId   String?  @map("tenant_id")
  userId     String?  @map("user_id")
  action     String
  resource   String
  resourceId String?  @map("resource_id")
  metadata   String?  @map("metadata")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@map("audit_logs")
}

model EmailVerification {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("email_verifications")
}

// ===================== Onboarding & Apps =====================

model TenantOnboarding {
  id        String   @id @default(cuid())
  tenantId  String   @unique @map("tenant_id")
  status    String   @default("in_progress") @map("status")
  step      Int      @default(1) @map("step")
  data      String   @default("{}") @map("data")
  deadline  DateTime? @map("deadline")

  // === Step Tracking ===
  completedSteps String? @map("completed_steps") // JSON array of step ids
  skippedSteps   String? @map("skipped_steps")   // JSON array
  lockedSteps    String? @map("locked_steps")    // JSON array (premium features)
  isLocked       Boolean @default(false) @map("is_locked")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_onboardings")
}

model TenantApp {
  id            String   @id @default(cuid())
  tenantId      String   @map("tenant_id")
  appId         String   @map("app_id")
  status        String   @default("installed") @map("status")
  installedAt   DateTime @default(now()) @map("installed_at")
  uninstalledAt DateTime? @map("uninstalled_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, appId])
  @@map("tenant_apps")
}

model AppCatalog {
  id           String   @id @default(cuid())
  appId        String   @unique @map("app_id")
  name         String   @map("name")
  description  String   @map("description")
  icon         String   @default("app") @map("icon")
  category     String   @default("other") @map("category")
  dependencies String   @default("[]") @map("dependencies")
  isOfficial   Boolean  @default(true) @map("is_official")
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("app_catalogs")
}

// ===================== Tenant Config & Features =====================

model TenantConfig {
  id          String   @id @default(cuid())
  tenantId    String   @unique @map("tenant_id")

  // === Brand Config ===
  brand       String?  // JSON: { name, slogan, logoUrl, faviconUrl, primaryColor }

  // === Auth Config ===
  auth        String?  // JSON: { methods: ['email','phone','social'], registerFlow, loginFlow }

  // === KYC Config ===
  kyc         String?  // JSON: { regions, level, amlEnabled, amlThreshold }

  // === Trading Config ===
  trading     String?  // JSON: { groups, leverage, spreadMode, platforms, lpProvider }

  // === Payment Config ===
  payment     String?  // JSON: { currencies, depositChannels, withdrawalChannels, feeTemplate }

  // === Third-Party Channels ===
  channels    String?  // JSON: { emailProvider, smsProvider, ekycProvider }

  // === MVP Mode ===
  mvpMode     Boolean  @default(true) @map("mvp_mode")

  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_configs")
}

model TenantFeature {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  featureKey      String   @map("feature_key")
  enabled         Boolean  @default(false)
  requiresUpgrade Boolean  @default(false) @map("requires_upgrade")
  upgradeTarget   String?  @map("upgrade_target") // e.g. "starter", "professional"
  reason          String?  // why disabled / upgrade required
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, featureKey])
  @@map("tenant_features")
}

model TenantDomain {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  domain       String   @unique
  type         String   // subdomain | custom
  status       String   @default("pending") // pending, active, failed
  cnameTarget  String?  @map("cname_target")
  sslStatus    String?  @map("ssl_status") // pending, issued, error
  verifiedAt   DateTime? @map("verified_at")
  failedReason String?  @map("failed_reason")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_domains")
}

model TenantNotification {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  type      String   // trial_reminder_7d, trial_reminder_3d, trial_reminder_1d, trial_expired, grace_period_started, grace_period_ending, retention_warning
  title     String
  content   String
  sentAt    DateTime @default(now()) @map("sent_at")
  readAt    DateTime? @map("read_at")
  channel   String   @default("in_app") // in_app, email, both
  metadata  String?  @map("metadata") // JSON: { daysLeft, plan, upgradeUrl }

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_notifications")
}

model TenantDataRetention {
  id              String   @id @default(cuid())
  tenantId        String   @unique @map("tenant_id")
  status          String   @default("active") // active, warning, expired, archived, purged
  retentionDays   Int      @default(90) @map("retention_days")
  retentionEndsAt DateTime @map("retention_ends_at")
  dataExported    Boolean  @default(false) @map("data_exported")
  exportUrl       String?  @map("export_url")
  exportRequestedAt DateTime? @map("export_requested_at")
  purgedAt        DateTime? @map("purged_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_data_retentions")
}

// ===================== Broker Core Models =====================

model KYCRecord {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  regionCode      String   @map("region_code")
  kycLevel        String   @map("kyc_level")
  status          String   @default("not_started") @map("status")
  documentType    String?  @map("document_type")
  documentFrontUrl String? @map("document_front_url")
  documentBackUrl String?  @map("document_back_url")
  selfieUrl       String?  @map("selfie_url")
  ocrConfidence   Float?   @map("ocr_confidence")
  livenessPassed  Boolean? @map("liveness_passed")
  amlPassed       Boolean? @default(false) @map("aml_passed")
  amlRiskScore    Float?   @map("aml_risk_score")
  personalInfo    String?  @map("personal_info") // JSON
  flags           String   @default("[]") @map("flags") // JSON array
  submittedAt     DateTime? @map("submitted_at")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?  @map("reviewed_by")
  rejectionReason String?  @map("rejection_reason")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewLogs  KYCReviewLog[]

  @@map("kyc_records")
}

model KYCReviewLog {
  id         String   @id @default(cuid())
  kycId      String   @map("kyc_id")
  adminId    String   @map("admin_id")
  action     String
  fromStatus String?  @map("from_status")
  toStatus   String   @map("to_status")
  reason     String?
  notes      String?
  createdAt  DateTime @default(now()) @map("created_at")

  kycRecord KYCRecord @relation(fields: [kycId], references: [id], onDelete: Cascade)

  @@map("kyc_review_logs")
}

model KYCSubmission {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  type        String   // supplemental, document_update, etc.
  status      String   @default("pending") @map("status")
  payload     String   @map("payload") // JSON
  response    String?  @map("response") // JSON
  reviewedBy  String?  @map("reviewed_by")
  reviewedAt  DateTime? @map("reviewed_at")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("kyc_submissions")
}

model MTAccount {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  mtLogin     String   @unique @map("mt_login")
  mtPassword  String   @map("mt_password")
  group       String
  leverage    Int      @default(100)
  balance     Float    @default(0)
  equity      Float    @default(0)
  margin      Float    @default(0)
  freeMargin  Float    @default(0) @map("free_margin")
  currency    String   @default("USD")
  status      String   @default("active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  orders    Order[]
  positions Position[]

  @@map("mt_accounts")
}

model Wallet {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  currency  String
  balance   Float    @default(0)
  frozen    Float    @default(0)
  available Float    @default(0)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([userId, currency])
  @@map("wallets")
}

model Transaction {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  walletId    String   @map("wallet_id")
  type        String   // deposit, withdrawal, transfer, commission
  amount      Float
  fee         Float    @default(0)
  currency    String
  status      String   @default("pending") // pending, processing, completed, failed, cancelled
  method      String?  // usdt_trc20, bank_transfer, stripe, etc.
  txHash      String?  @map("tx_hash")
  address     String?
  description String?
  metadata    String?  @map("metadata") // JSON
  processedAt DateTime? @map("processed_at")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  wallet Wallet @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@map("transactions")
}

model Order {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  mtTicket    String?  @unique @map("mt_ticket")
  symbol      String
  type        String   // buy, sell
  volume      Float
  openPrice   Float    @map("open_price")
  closePrice  Float?   @map("close_price")
  profit      Float?   @default(0)
  swap        Float?   @default(0)
  commission  Float?   @default(0)
  status      String   @default("open") // open, closed, cancelled
  openTime    DateTime @map("open_time")
  closeTime   DateTime? @map("close_time")
  createdAt   DateTime @default(now()) @map("created_at")

  account MTAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("orders")
}

model Position {
  id          String   @id @default(cuid())
  accountId   String   @map("account_id")
  symbol      String
  type        String   // buy, sell
  volume      Float
  openPrice   Float    @map("open_price")
  currentPrice Float?  @map("current_price")
  profit      Float?   @default(0)
  swap        Float?   @default(0)
  openTime    DateTime @map("open_time")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  account MTAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@map("positions")
}

model IBPartner {
  id              String   @id @default(cuid())
  userId          String   @unique @map("user_id")
  parentId        String?  @map("parent_id")
  level           Int      @default(1)
  code            String   @unique
  commissionRate  Float    @default(0) @map("commission_rate")
  totalCommission Float    @default(0) @map("total_commission")
  totalClients    Int      @default(0) @map("total_clients")
  status          String   @default("active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  commissions  CommissionRecord[]

  @@map("ib_partners")
}

model CommissionRecord {
  id          String   @id @default(cuid())
  ibId        String   @map("ib_id")
  clientId    String   @map("client_id")
  orderId     String?  @map("order_id")
  amount      Float
  currency    String   @default("USD")
  status      String   @default("pending") // pending, paid, cancelled
  period      String
  paidAt      DateTime? @map("paid_at")
  createdAt   DateTime @default(now()) @map("created_at")

  ibPartner IBPartner @relation(fields: [ibId], references: [id], onDelete: Cascade)

  @@map("commission_records")
}

model RiskEvent {
  id          String   @id @default(cuid())
  type        String   // margin_call, stop_out, nbp, large_deposit, etc.
  severity    String   @default("medium") // low, medium, high, critical
  userId      String   @map("user_id")
  accountId   String?  @map("account_id")
  description String?
  metadata    String?  @map("metadata") // JSON
  resolved    Boolean  @default(false)
  resolvedAt  DateTime? @map("resolved_at")
  resolvedBy  String?  @map("resolved_by")
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("risk_events")
}

model BlacklistEntry {
  id        String   @id @default(cuid())
  type      String   // email, phone, ip, document, name
  value     String
  reason    String?
  source    String   @default("manual") // manual, system, external
  createdBy String?  @map("created_by")
  createdAt DateTime @default(now()) @map("created_at")
  expiresAt DateTime? @map("expires_at")

  @@unique([type, value])
  @@map("blacklist_entries")
}

model Notification {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  type      String   // kyc, deposit, withdrawal, trade, system
  title     String
  content   String
  read      Boolean  @default(false)
  actionUrl String?  @map("action_url")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("notifications")
}
